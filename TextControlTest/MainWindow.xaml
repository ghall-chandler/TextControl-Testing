<Window x:Class="TextControlTest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:tx="clr-namespace:TXTextControl.WPF;assembly=TXTextControl.WPF"
        mc:Ignorable="d"
        Title="PDF Preview Bug Repro" Height="450" Width="800">
    <DockPanel>
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top">
            <Button Content="Generate Preview Sync" Click="SyncPreview" Margin="10,10,10,10" />
            <Button Content="Generate Preview Async" Click="AsyncPreview" Margin="10,10,10,10" />
        </StackPanel>
        <tx:TextControl Name="TextControl"  Loaded="TextControl_Loaded"/>
    </DockPanel>
</Window>
